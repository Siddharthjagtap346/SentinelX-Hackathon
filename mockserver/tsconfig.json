{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  // include all TypeScript files under the mockserver folder
  "include": ["src/**/*.ts", "**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
